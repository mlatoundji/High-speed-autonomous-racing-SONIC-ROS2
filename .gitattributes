# This repo is built and run on Linux (ROS 2 Humble, Gazebo Classic).
# Force LF for all text files so a Windows clone with autocrlf=true
# cannot re-introduce CRLF, which breaks `#!/usr/bin/env python3` shebangs
# on Linux ("/usr/bin/env: 'python3\r': No such file or directory").

*           text=auto eol=lf

*.py        text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.xacro     text eol=lf
*.urdf      text eol=lf
*.world     text eol=lf
*.sdf       text eol=lf
*.cmake     text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.csv       text eol=lf
CMakeLists.txt text eol=lf
Dockerfile  text eol=lf

# Binary assets - never normalize line endings on these.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.dae       binary
*.stl       binary
*.obj       binary
*.mtl       binary
*.fbx       binary
*.bag       binary
*.db3       binary
*.pdf       binary
